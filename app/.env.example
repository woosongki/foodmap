# 네이버 클라우드 플랫폼 - Maps JavaScript API
# https://console.ncloud.com → AI·NAVER API → Maps
VITE_NAVER_MAP_CLIENT_ID=여기에_NCP_Client_ID

# Supabase
# https://supabase.com → 프로젝트 설정 → API
VITE_SUPABASE_URL=https://xxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=여기에_anon_key

# 편집 비밀번호 (Vercel 환경변수에도 동일하게 등록)
VITE_EDIT_PASSWORD=여기에_편집_비밀번호

# 네이버 검색 API (서버사이드 전용 - VITE_ 접두사 없음)
# https://developers.naver.com → 애플리케이션 등록 → 지역 검색
NAVER_CLIENT_ID=여기에_검색API_Client_ID
NAVER_CLIENT_SECRET=여기에_검색API_Client_Secret
